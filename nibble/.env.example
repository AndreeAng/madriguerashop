# === Base ===
# Este archivo es la PLANTILLA para producción. En dev, copiar a `.env` y
# cambiar NODE_ENV=development + URLs locales. Vercel/Next setean NODE_ENV
# automáticamente; sobrescribir solo si sabes lo que haces.
NODE_ENV=production
APP_URL=https://madrigueras.shop
# NextAuth v5 usa AUTH_* como nombres canónicos. NEXTAUTH_* funcionan por
# retrocompat pero pueden romper entre betas — prefiere AUTH_*.
AUTH_URL=https://madrigueras.shop
# Genera con: openssl rand -base64 32
AUTH_SECRET=

# === Cifrado de secretos en DB ===
# Clave AES-256-GCM para cifrar columnas sensibles (ej. SIAT tokenDelegado).
# DEBE ser distinta de AUTH_SECRET y de DATABASE_URL — vive en un secret
# manager separado para que un leak de DB no rompa el cifrado.
# Genera con: openssl rand -base64 32
ENCRYPTION_KEY=

# === Database ===
# IMPORTANTE para Vercel serverless + Neon: agrega `?connection_limit=1&pool_timeout=20`
# al URL. Cada lambda abre su propio PrismaClient (no se reusa entre
# invocaciones); sin el cap por instancia, un spike puede agotar las
# ~100 conexiones del free tier de Neon → `too many clients`.
# Si usas el pooler de Neon (URL termina en `-pooler...`), añade también
# `&pgbouncer=true` para deshabilitar prepared statements (PgBouncer en
# transaction pooling no los soporta).
# Para `prisma migrate deploy` usa DIRECT_URL apuntando al endpoint sin pooler.
DATABASE_URL=postgresql://user:pass@postgres:5432/madrigueras?schema=public&connection_limit=1&pool_timeout=20

# === Database direct connection (para migrations) ===
# `prisma migrate deploy` necesita conexión SIN pooler (PgBouncer no
# soporta los prepared statements que usa el migration runner). En Neon,
# usar el endpoint que NO contiene `-pooler` en el hostname. El schema
# expone `directUrl` que lee esta variable.
DIRECT_URL=postgresql://user:pass@direct-host:5432/madrigueras?schema=public

# === Storage ===
#
# DOS MODOS soportados:
#
# 1) Vercel Blob (RECOMENDADO en prod serverless — Vercel filesystem es
#    read-only excepto /tmp, así que escribir a `public/uploads/` falla).
#    Para activar: en el dashboard de Vercel → Storage → Create Database →
#    Blob → conectar al proyecto. Eso setea BLOB_READ_WRITE_TOKEN
#    automáticamente. Mientras esta variable esté presente, `saveImage`
#    guarda en Blob; los uploads (logo, banner, productos, QR, comprobantes)
#    devuelven URLs `https://<id>.public.blob.vercel-storage.com/...`.
#    Para los comprobantes (private en filesystem) la URL incluye un UUID
#    unguessable como token de obscurity-by-default.
BLOB_READ_WRITE_TOKEN=
#
# 2) Filesystem local (dev). Si BLOB_READ_WRITE_TOKEN está vacío, `saveImage`
#    cae al modo filesystem y usa estas vars:
UPLOAD_DIR=/var/www/uploads
PUBLIC_UPLOADS_URL=https://madrigueras.shop/uploads
# Comprobantes de pago: directorio PRIVADO, NO debe ser servido por nginx
# directamente. Se accede por /api/uploads/proof/<storeId>/<file> con auth.
PROOF_UPLOAD_DIR=/var/www/private-uploads/proof
MAX_UPLOAD_SIZE_MB=5

# === Email (Brevo recomendado: 300/día gratis, sin tarjeta) ===
# Crear cuenta gratis en https://www.brevo.com → SMTP & API → SMTP relay
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Madriguera Shop <no-reply@madrigueras.shop>"

# === Logging ===
# Sentry — crear proyecto gratuito en https://sentry.io (5k errores/mes free).
# Sin DSN, los errores caen sólo a stdout.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Sentry source maps + sourcemap upload en CI/Vercel. AUTH_TOKEN solo en
# CI, NUNCA en el repo. ORG y PROJECT son slugs del dashboard de Sentry.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Diferencia staging de production en el dashboard de Sentry. Vercel
# setea NODE_ENV=production en ambos, así que sin esta variable los
# errores de staging contaminan las alertas de prod. Valores: production,
# staging, development.
APP_ENV=production
NEXT_PUBLIC_APP_ENV=production

# === Rate limit (Upstash) ===
# OBLIGATORIO en producción serverless (Vercel/Cloudflare) y en VPS con
# cluster de workers. Sin estas vars la app cae al limiter en memoria que
# NO sobrevive a cold starts ni multi-worker.
# Crear DB gratis en https://upstash.com (10k requests/día free).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Billing ===
BILLING_INVOICE_PREFIX=NIB-
BILLING_DUE_DAYS=7
BILLING_GRACE_DAYS=5
# Secret para autenticar al cron. Genera con `openssl rand -base64 32`.
CRON_SECRET=
# QR del SaaS (donde los dueños de tienda te pagan a vos).
# Estos vars son LA SEMILLA INICIAL: la primera vez que corre la app, se
# crea el row `SaasSettings(id="default")` con estos valores. A partir de
# ahí el super admin los edita en /admin/settings y la DB toma precedencia.
SAAS_PAYMENT_QR_URL=
SAAS_PAYMENT_INSTRUCTIONS="Escanea el QR y paga el monto exacto. Sube el comprobante para que verifiquemos."

# === Facturación SIAT (Bolivia) ===
# `sandbox` (piloto del SIN, no genera facturas reales) o `production`.
# Cualquier otro valor cae a sandbox con un warning en el log. NUNCA dejar
# vacío en producción — emitiría facturas al piloto sin que nadie note.
SIAT_MODE=sandbox
# Código del sistema asignado por el SIN al certificar el SaaS. Obligatorio
# para emitir facturas en modo production.
SIAT_SISTEMA_CODIGO=
# Cambia `false` a `true` solo después de validar el algoritmo de CUF
# contra los test vectors oficiales del SIN. Ver `lib/billing/siat/cuf.ts`.
SIAT_CUF_VALIDATED=false

# === Reverse proxy / rate limiting ===
# Cuando la app corre detrás de un proxy (Vercel auto, nginx, Cloudflare),
# `x-forwarded-for` es confiable. En entornos sin proxy (dev local,
# Docker bare) el header es falsificable — dejar en false. Vercel lo
# detecta automáticamente; si seteás esta variable, sobreescribe.
RATE_LIMIT_TRUST_PROXY=auto

# === Feature flags ===
FEATURE_DYNAMIC_QR=false
FEATURE_AI_CHATBOT=false
FEATURE_MULTI_BRANCH=false

# === Datos legales de la entidad operadora ===
# Mientras estén vacíos, /terminos y /privacidad muestran un banner de
# "borrador no vigente". Completar antes del lanzamiento público.
LEGAL_ENTITY_NAME=
LEGAL_ENTITY_ADDRESS=
LEGAL_ENTITY_TAX_ID=
LEGAL_ENTITY_CONTACT_EMAIL=hola@madrigueras.shop

# === Super Admin seed ===
SEED_SUPER_ADMIN_EMAIL=
# Genera con: openssl rand -base64 24
# NUNCA uses "admin123" ni similares. Aun en staging un valor débil habilita
# brute force trivial al panel de admin.
SEED_SUPER_ADMIN_PASSWORD=
# Password único para los 5 owners de las tiendas demo (sólo en dev/staging).
# Si está vacío, el seed salta las tiendas demo en lugar de fallar duro.
SEED_DEMO_OWNER_PASSWORD=
