# === Base ===
NODE_ENV=production
APP_URL=https://nibble.bo
NEXTAUTH_URL=https://nibble.bo
NEXTAUTH_SECRET=

# === Database ===
DATABASE_URL=postgresql://user:pass@postgres:5432/nibble?schema=public

# === Storage ===
UPLOAD_DIR=/var/www/uploads
PUBLIC_UPLOADS_URL=https://nibble.bo/uploads
MAX_UPLOAD_SIZE_MB=5

# === Email ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Nibble <no-reply@nibble.bo>"

# === Logging ===
LOG_LEVEL=info
SENTRY_DSN=

# === Billing ===
BILLING_INVOICE_PREFIX=NIB-
BILLING_DUE_DAYS=7
BILLING_GRACE_DAYS=5

# === Feature flags ===
FEATURE_DYNAMIC_QR=false
FEATURE_AI_CHATBOT=false
FEATURE_MULTI_BRANCH=false

# === Super Admin seed ===
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
