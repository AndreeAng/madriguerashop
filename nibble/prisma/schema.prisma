// =================================================================
// schema.prisma — Nibble (SaaS de Tienda Virtual para Bolivia)
// Source of truth: SRS §4.1
// =================================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============== USUARIOS Y AUTH ==============

enum Role {
  SUPER_ADMIN
  STORE_OWNER
  CASHIER
  CUSTOMER
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  email             String?   @unique
  phone             String?   @unique
  passwordHash      String
  role              Role
  fullName          String?
  storeId           String?
  store             Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  isActive          Boolean   @default(true)
  // TODO: implementar flujo de verificación de email (envío de link al
  // registrarse, /verify-email/[token]). Hasta entonces este campo es
  // siempre NULL — pero lo dejamos porque agregarlo más tarde requiere
  // migration y el costo de mantenerlo NULL es cero.
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  // Marcador para invalidar JWTs activos cuando se resetea/cambia la
  // password. El callback `jwt` de auth.ts compara este timestamp contra
  // el del token: si el JWT fue emitido antes, lo invalida en el próximo
  // revalidate. Sin esto, un atacante que interceptó un link de recovery
  // mientras la víctima estaba logueada compartía sesión hasta 5 min.
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  passwordResets     PasswordReset[]
  customers          Customer[]
  orderEventsCreated OrderEvent[]
  paymentsVerified   Order[]         @relation("PaymentVerifier")
  invoicesVerified   Invoice[]       @relation("InvoiceVerifier")

  @@index([storeId])
  @@index([role])
}

// NOTA: el modelo Session fue eliminado. NextAuth está configurado con
// strategy "jwt" sin PrismaAdapter, así que nunca escribió a esta tabla.
// La revocación de sesiones de usuarios suspendidos ocurre en el callback
// `jwt` de auth.ts vía re-validación periódica de `isActive`.

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ============== TIENDAS ==============

enum StoreStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

// Verticales que el merchant elige al registrar/admin elige al crear.
// Cada vertical fija el copy del storefront (`storefrontCopy`) y el
// template inicial. Si una vertical nueva NO tiene template propio,
// `pickTemplateForVertical` cae a RETAIL como genérico — el owner
// puede personalizar después desde su dashboard.
enum StoreVertical {
  RESTAURANT
  FOOD_TRUCK
  BAKERY
  GROCERY
  RETAIL
  HARDWARE
  BEAUTY
  HEALTH
  SERVICES
  OTHER
}

model Store {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  vertical    StoreVertical
  status      StoreStatus   @default(ACTIVE)
  description String?

  // Branding
  logoUrl         String?
  faviconUrl      String?
  bannerUrl       String?
  primaryColor    String   @default("#3B82F6")
  secondaryColor  String   @default("#1E40AF")
  accentColor     String   @default("#F59E0B")
  fontFamily      String   @default("Inter")
  templateId      String
  template        Template @relation(fields: [templateId], references: [id], onDelete: Restrict)
  darkModeAllowed Boolean  @default(true)

  // Contacto
  whatsappPhone String
  email         String?
  addressText   String?
  city          String?
  lat           Float?
  lng           Float?

  // Redes
  instagram String?
  facebook  String?
  tiktok    String?
  website   String?

  // Pagos
  qrImageUrl            String?
  qrInstructions        String? @db.Text
  acceptsCashOnDelivery Boolean @default(true)
  acceptsQR             Boolean @default(true)

  // Delivery
  deliveryEnabled    Boolean  @default(true)
  pickupEnabled      Boolean  @default(false)
  defaultDeliveryFee Decimal? @db.Decimal(10, 2)
  deliveryNote       String?
  freeDeliveryAbove  Decimal? @db.Decimal(10, 2)

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImageUrl      String?

  // Plan
  planId             String
  plan               Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)
  billingCycle       BillingCycle @default(MONTHLY)
  trialEndsAt        DateTime?
  subscriptionEndsAt DateTime?
  nextInvoiceAt      DateTime?

  // Operación
  isPubliclyListed Boolean @default(true)
  ownerNotes       String? @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  suspendedAt     DateTime?
  suspendedReason String?
  // Timestamp del momento en que la tienda pasó a CANCELLED. Distinto de
  // `suspendedAt`. Usado para métricas de churn — antes el cálculo
  // dependía de suspendedAt y daba siempre números casi nulos.
  cancelledAt     DateTime?

  users         User[]
  categories    Category[]
  products      Product[]
  orders        Order[]
  customers     Customer[]
  coupons       Coupon[]
  banners       Banner[]
  popups        Popup[]
  deliveryZones DeliveryZone[]
  storeHours    StoreHours[]
  invoices      Invoice[]
  pageViews     PageView[]
  carts         Cart[]
  alerts        Alert[]
  bookings      Booking[]
  bookingBlocks BookingBlock[]
  orderCounter  StoreOrderCounter?

  @@index([status])
  @@index([slug])
}

model Template {
  id           String        @id @default(cuid())
  name         String
  vertical     StoreVertical
  description  String
  previewUrl   String
  componentKey String        @unique
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  stores       Store[]

  @@index([vertical, isActive])
}

model StoreHours {
  id        String  @id @default(cuid())
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  openTime  String
  closeTime String
  isClosed  Boolean @default(false)

  @@unique([storeId, dayOfWeek])
}

// ============== CATÁLOGO ==============

model Category {
  id          String     @id @default(cuid())
  storeId     String
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  sortOrder   Int        @default(0)
  isVisible   Boolean    @default(true)
  products    Product[]

  @@unique([storeId, slug])
  @@index([parentId])
  @@index([storeId])
}

model Product {
  id               String  @id @default(cuid())
  storeId          String
  store            Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sku              String?
  name             String
  slug             String
  description      String? @db.Text
  shortDescription String?

  basePrice    Decimal  @db.Decimal(10, 2)
  comparePrice Decimal? @db.Decimal(10, 2)

  manageStock   Boolean @default(false)
  stock         Int     @default(0)
  lowStockAlert Int?

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  isNew            Boolean @default(false)
  isBestSeller     Boolean @default(false)
  customLabel      String?
  customLabelColor String?

  hasSchedule   Boolean @default(false)
  availableFrom String?
  availableTo   String?
  availableDays Int[]   @default([])

  // ============== Bookable services ==============
  // Producto reservable (corte de pelo, manicure, masaje): el cliente
  // elige día y hora en lugar de comprar. Las reservas viven en `Booking`.
  // `bookingDurationMin` define cuánto dura el servicio (slot por slot).
  // `bookingBufferMin` es el descanso entre reservas (limpieza, reset).
  isBookable         Boolean @default(false)
  bookingDurationMin Int     @default(30)
  bookingBufferMin   Int     @default(0)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  images     ProductImage[]
  variants   ProductVariant[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  bookings   Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([categoryId])
  @@index([isActive, storeId])
  @@index([isFeatured])
}

// ============== BOOKING (reservas para servicios) ==============

enum BookingStatus {
  PENDING // cliente reservó, owner aún no confirmó
  CONFIRMED // owner confirmó la reserva
  CANCELLED // alguien la canceló (owner o cliente)
  COMPLETED // el servicio se prestó
  NO_SHOW // el cliente no apareció
}

model Booking {
  id        String  @id @default(cuid())
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId String
  // `Restrict` — borrar un producto con reservas debe fallar, igual que
  // OrderItem.product. Antes era Cascade, lo que silenciosamente hacía
  // desaparecer reservas confirmadas (cliente esperando) si alguien
  // hard-deleteaba el producto desde una migración o admin tool.
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  customerName  String
  customerPhone String
  customerEmail String?
  notes         String? @db.Text

  // Slot reservado. `endsAt` se calcula al crear como
  // `startsAt + product.bookingDurationMin + bufferMin` para que las
  // queries de "está libre este slot?" sean simples comparaciones de rangos.
  startsAt DateTime
  endsAt   DateTime
  status   BookingStatus @default(PENDING)

  // Token público para que el cliente pueda ver/cancelar su reserva.
  // Mismo patrón que `Order.trackingToken` — unguessable, 132 bits.
  trackingToken String @unique

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  confirmedAt  DateTime?
  cancelledAt  DateTime?
  completedAt  DateTime?
  noShowAt     DateTime?
  cancelReason String?

  // Índice para query de slots: dado producto y rango de fechas,
  // encontrar bookings activos rápidamente.
  @@index([productId, startsAt])
  @@index([storeId, startsAt])
  @@index([status])
}

// Bloqueos de disponibilidad: el owner marca un rango de tiempo donde
// NO atiende reservas (vacaciones, día libre, almuerzo, capacitación).
// El slot generator descarta cualquier hora que caiga dentro de un bloque
// activo, incluso si el storeHours del día está abierto.
//
// Por ahora bloqueos son a nivel TIENDA (afectan todos los servicios).
// Si más adelante necesitamos por servicio, agregamos `productId?` opcional.
model BookingBlock {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())

  // Index para query rápida "¿qué bloques activos hay para este storeId
  // en este rango de tiempo?".
  @@index([storeId, startsAt])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)

  @@index([productId])
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name         String
  sku          String?
  price        Decimal? @db.Decimal(10, 2)
  comparePrice Decimal? @db.Decimal(10, 2)
  manageStock  Boolean  @default(false)
  stock        Int      @default(0)
  attributes   Json
  imageUrl     String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
}

// ============== PROMOCIONES ==============

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

model Coupon {
  id                String     @id @default(cuid())
  storeId           String
  store             Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  code              String
  description       String?
  type              CouponType
  value             Decimal    @db.Decimal(10, 2)
  minOrderAmount    Decimal?   @db.Decimal(10, 2)
  maxDiscountAmount Decimal?   @db.Decimal(10, 2)
  usageLimit        Int?
  usageLimitPerUser Int?
  usedCount         Int        @default(0)
  validFrom         DateTime
  validTo           DateTime
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())

  orders Order[]
  usages CouponUsage[]
  // `@@unique([storeId, code])` ya crea un B-tree sobre `(storeId, code)`,
  // por lo que un `@@index([storeId])` separado sería redundante (queries
  // que solo filtran por storeId usan el prefijo izquierdo del unique).

  @@unique([storeId, code])
}

model Banner {
  id             String    @id @default(cuid())
  storeId        String
  store          Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title          String?
  subtitle       String?
  imageUrl       String
  mobileImageUrl String?
  linkUrl        String?
  position       String    @default("hero")
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  validFrom      DateTime?
  validTo        DateTime?
  createdAt      DateTime  @default(now())

  @@index([storeId, isActive])
}

model Popup {
  id                 String    @id @default(cuid())
  storeId            String
  store              Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title              String
  message            String    @db.Text
  imageUrl           String?
  ctaText            String?
  ctaUrl             String?
  delaySeconds       Int       @default(3)
  showOncePerSession Boolean   @default(true)
  isActive           Boolean   @default(true)
  validFrom          DateTime?
  validTo            DateTime?
  createdAt          DateTime  @default(now())

  @@index([storeId, isActive])
}

// ============== DELIVERY ==============

model DeliveryZone {
  id            String  @id @default(cuid())
  storeId       String
  store         Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name          String
  polygon       Json
  fee           Decimal @db.Decimal(10, 2)
  estimatedTime String?
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)

  orders Order[]

  @@index([storeId])
}

// ============== CARRITO Y CUSTOMERS ==============

model Customer {
  id      String  @id @default(cuid())
  storeId String
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  // Un mismo User puede ser cliente en múltiples tiendas, por eso el unique
  // es compuesto con storeId. NULL es ignorado por unique en Postgres, lo
  // que permite muchos guest customers (userId=null) por tienda.
  userId  String?
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  fullName String
  phone    String
  email    String?

  lastAddressText String?
  lastLat         Float?
  lastLng         Float?
  lastNote        String?

  ordersCount Int       @default(0)
  totalSpent  Decimal   @default(0) @db.Decimal(10, 2)
  lastOrderAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
  // `@@index([storeId])` redundante: `@@unique([storeId, phone])` y
  // `@@index([storeId, userId])` ya cubren queries que filtran solo por
  // storeId via prefijo izquierdo del B-tree.

  @@unique([storeId, phone])
  // Nota: la unicidad real de (storeId, userId) vive como índice parcial
  // SQL `WHERE userId IS NOT NULL` (ver migration). Prisma no soporta
  // unique parciales en la DSL, así que solo declaramos @@index acá para
  // que el query planner lo use, sin que Prisma intente "arreglarlo".
  @@index([storeId, userId])
}

model Cart {
  id         String     @id @default(cuid())
  storeId    String
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerId String?
  guestToken String?
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  expiresAt  DateTime

  @@index([storeId])
  @@index([guestToken])
  @@index([expiresAt])
}

model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity  Int
  notes     String?
  unitPrice Decimal         @db.Decimal(10, 2)
  createdAt DateTime        @default(now())

  @@unique([cartId, productId, variantId])
  @@index([productId])
}

// ============== PEDIDOS ==============

enum OrderStatus {
  PENDING_PAYMENT
  NEW
  CONFIRMED
  PREPARING
  IN_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  QR_STATIC
  QR_DYNAMIC
  CASH_ON_DELIVERY
}

/// Estados del pago de un pedido.
///
///   - PENDING: pago en proceso (CoD esperando entrega).
///   - AWAITING_VERIFICATION: cliente subió comprobante QR; owner debe verificar.
///   - VERIFIED: pago confirmado por el owner. Stock aplicado.
///   - REJECTED: comprobante rechazado por el owner. Sin efecto fiscal.
///   - REFUNDED: pago verificado y posteriormente devuelto. Por ahora se
///     setea manualmente vía script de soporte o admin SQL — aún no hay
///     UI de refund. Los reembolsos se coordinan por WhatsApp y el admin
///     marca el estado a posteriori. Cualquier dashboard que cuente
///     revenue debe filtrar `paymentStatus != REFUNDED`.
enum PaymentStatus {
  PENDING
  AWAITING_VERIFICATION
  VERIFIED
  REJECTED
  REFUNDED
}

model Order {
  id            String @id @default(cuid())
  orderNumber   Int
  trackingToken String @unique

  storeId    String
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Restrict)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  customerName  String
  customerPhone String
  customerEmail String?

  deliveryAddress String        @db.Text
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryNote    String?
  deliveryZoneId  String?
  deliveryZone    DeliveryZone? @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)

  items OrderItem[]

  subtotal       Decimal  @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  deliveryFee    Decimal? @db.Decimal(10, 2)
  total          Decimal  @db.Decimal(10, 2)

  couponId   String?
  coupon     Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode String?

  status OrderStatus @default(NEW)

  paymentMethod         PaymentMethod
  paymentStatus         PaymentStatus @default(PENDING)
  paymentProofUrl       String?
  paymentVerifiedAt     DateTime?
  paymentVerifiedById   String?
  paymentVerifiedBy     User?         @relation("PaymentVerifier", fields: [paymentVerifiedById], references: [id], onDelete: SetNull)
  paymentRejectedReason String?

  // Indica si el decremento de stock + actualización de Customer counters
  // ya fue aplicado para este pedido. CoD aplica al crear; QR aplica al
  // verificar pago. Si se cancela un pedido con stockApplied=true, se
  // restituye y se baja el flag.
  stockApplied Boolean @default(false)

  customerNotes String? @db.Text
  ownerNotes    String? @db.Text

  // Pedido programado: el cliente eligió día/hora futura para entrega o
  // recojo. Útil cuando la tienda está cerrada (el cliente paga ahora, el
  // local atiende en horario) o cuando el cliente pide "delivery para
  // mañana 14:00" por preferencia.
  //
  // Restricciones:
  //   - Si se setea, debe caer dentro del horario abierto de la tienda
  //     (validado en server action `createOrder`).
  //   - Si es NULL, el pedido se considera "lo antes posible" (default).
  scheduledFor DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  // `newAt` rastrea cuándo entró el pedido al flujo activo (NEW). Para
  // pedidos CoD coincide con `createdAt`. Para QR, se setea en la
  // verificación de pago (transición PENDING_PAYMENT → NEW). Sin este
  // timestamp no se podía medir "tiempo de verificación de QR".
  newAt        DateTime?
  confirmedAt  DateTime?
  preparingAt  DateTime?
  inDeliveryAt DateTime?
  deliveredAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  whatsappOpenedAt DateTime?
  whatsappMessage  String?   @db.Text

  events       OrderEvent[]
  couponUsages CouponUsage[]

  @@unique([storeId, orderNumber])
  @@index([storeId, status])
  @@index([storeId, paymentStatus])
  @@index([storeId, createdAt])
  @@index([customerId])
  @@index([couponId])
  @@index([createdAt])
  @@index([deliveryLat, deliveryLng])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  // onDelete: Restrict — un producto con ventas históricas no se puede borrar
  // físicamente. La UI de productos sólo permite isActive=false (soft delete).
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName     String
  productImageUrl String?
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantName     String?
  quantity        Int
  unitPrice       Decimal         @db.Decimal(10, 2)
  subtotal        Decimal         @db.Decimal(10, 2)
  notes           String?

  @@index([orderId])
  @@index([productId])
}

model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type        String
  description String
  byUserId    String?
  byUser      User?    @relation(fields: [byUserId], references: [id], onDelete: SetNull)
  byUserName  String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([orderId])
}

// ============== BILLING ==============

enum BillingCycle {
  MONTHLY
  YEARLY
}

model Plan {
  id              String  @id @default(cuid())
  name            String  @unique
  slug            String  @unique
  description     String
  monthlyPriceBob Decimal @db.Decimal(10, 2)
  yearlyPriceBob  Decimal @db.Decimal(10, 2)

  maxProducts         Int?
  maxOrdersPerMonth   Int?
  maxStaff            Int  @default(1)
  maxImagesPerProduct Int  @default(5)

  removeWatermark   Boolean @default(false)
  prioritySupport   Boolean @default(false)
  dynamicQR         Boolean @default(false)
  multiBranch       Boolean @default(false)
  advancedAnalytics Boolean @default(false)
  emailMarketing    Boolean @default(false)
  aiChatbot         Boolean @default(false)
  customCss         Boolean @default(false)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  stores Store[]
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique
  storeId       String
  store         Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("BOB")

  periodStart DateTime
  periodEnd   DateTime

  status       InvoiceStatus @default(PENDING)
  dueDate      DateTime
  paidAt       DateTime?
  paidProofUrl String?
  verifiedAt   DateTime?
  verifiedById String?
  verifiedBy   User?         @relation("InvoiceVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)

  reminderSentAt DateTime?
  remindersCount Int       @default(0)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, periodStart])
  @@index([storeId])
  @@index([status, dueDate])
}

// ============== ANALYTICS ==============

model PageView {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  path         String
  productId    String?
  referrer     String?
  userAgent    String?
  ip           String?
  country      String?
  city         String?
  visitorToken String?
  sessionToken String?
  createdAt    DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([productId])
  @@index([visitorToken])
}

// NOTA: los modelos AiChatSession / AiChatMessage fueron eliminados.
// El feature de chatbot está en roadmap V2 sin diseño concreto — cuando
// se implemente, agregar de nuevo con el scope real. Mantener modelos
// vacíos solo creaba confusión ("¿debería usar esto?").

// ============== AUDIT LOG ==============

model AuditLog {
  id        String   @id @default(cuid())
  storeId   String?
  actorId   String?
  actorRole String?
  action    String
  target    String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([storeId])
  @@index([actorId])
  // Índice compuesto para paginación de `/admin/auditoria` que filtra por
  // `action` (prefijo) + ORDER BY createdAt DESC. Reemplaza los dos
  // separados que requerían sort en memoria.
  @@index([action, createdAt(sort: Desc)])
}

// ============== CRON LOCK ==============
// Lock distribuido para crones idempotentes. Cada job toma su row con
// `name` único; si ya hay uno RUNNING reciente, el siguiente trigger
// vuelve sin correr. Evita doble emisión cuando Vercel reintenta.

enum CronRunStatus {
  RUNNING
  DONE
  FAILED
}

model CronRun {
  id         String        @id @default(cuid())
  name       String
  status     CronRunStatus @default(RUNNING)
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  error      String?       @db.Text
  result     Json?

  @@index([name, status, startedAt])
}

// ============== ALERTAS OPERATIVAS ==============
// Eventos que requieren atención del super admin: cron caído, comprobantes
// fraudulentos, login attacks, tiendas con drop de tráfico. La detección
// corre dentro del cron de billing y crea filas idempotentes vía dedupeKey.

enum AlertType {
  CRON_FAILED
  PROOF_REUSED
  LOGIN_ATTACK
  STORE_TRAFFIC_DROP
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model Alert {
  id               String        @id @default(cuid())
  type             AlertType
  severity         AlertSeverity @default(MEDIUM)
  title            String
  description      String        @db.Text
  data             Json?
  storeId          String?
  store            Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  status           AlertStatus   @default(OPEN)
  // Clave de deduplicación: ej. "cron_failed:<runId>", "proof_reused:<hash>",
  // "login_attack:<ip>:<windowStart>", "traffic_drop:<storeId>:<weekStart>".
  // Permite que la detección sea idempotente entre runs.
  dedupeKey        String        @unique
  createdAt        DateTime      @default(now())
  acknowledgedAt   DateTime?
  acknowledgedById String?
  resolvedAt       DateTime?
  resolvedById     String?

  @@index([status, createdAt])
  @@index([type])
  @@index([storeId])
}

// ============== CONFIG GLOBAL DEL SAAS ==============
// Singleton (id="default"). Reemplaza env vars que el super admin necesita
// poder cambiar sin redeploy: QR del SaaS, días de gracia, feature flags.

model SaasSettings {
  id                   String   @id @default("default")
  paymentQrUrl         String?
  paymentInstructions  String   @default("Escanea el QR y paga el monto exacto. Sube el comprobante para que verifiquemos.")
  billingInvoicePrefix String   @default("NIB-")
  billingDueDays       Int      @default(7)
  billingGraceDays     Int      @default(5)
  featureDynamicQr     Boolean  @default(false)
  featureAiChatbot     Boolean  @default(false)
  featureMultiBranch   Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ============== COUNTERS ==============
// Filas singleton para secuencias atómicas (invoice number global). El
// `update({ data: { current: { increment: 1 } } })` toma row lock en Postgres,
// serializando lambdas concurrentes — más simple que `CREATE SEQUENCE`.

model BillingCounter {
  id      String @id // ej. "invoice"
  current Int    @default(0)
}

// Counter atómico por tienda para `Order.orderNumber`. El `update` con
// `increment` toma row lock en Postgres, garantizando unicidad entre
// requests concurrentes — reemplaza el patrón frágil `aggregate _max + 1`.
//
// FK a Store con onDelete: Cascade — cuando se borra una tienda, su
// counter se borra junto. Sin esta FK, los counters huérfanos quedan
// indefinidamente en DB (CUID prácticamente sin reutilización, pero
// basura acumulada).
model StoreOrderCounter {
  storeId String @id
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  current Int    @default(0)
}

// Registro de usos de cupón por cliente. Permite enforcing de
// `Coupon.usageLimitPerUser`. Una fila por (cupón, pedido); el
// `@@unique([couponId, orderId])` previene doble registro si una creación
// reintenta. El conteo de uso por cliente se obtiene con `count` filtrando
// por `couponId` + `customerPhone`.
model CouponUsage {
  id            String   @id @default(cuid())
  couponId      String
  // `Restrict` evita que borrar un cupón destruya su historial de uso.
  // Antes era Cascade — borrar un cupón eliminaba retroactivamente la
  // evidencia de qué clientes lo usaron, impidiendo auditar abusos de
  // `usageLimitPerUser`. Para borrar un cupón con usos, ahora hay que
  // hacer soft-delete (`isActive: false`).
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerPhone String
  createdAt     DateTime @default(now())

  @@unique([couponId, orderId])
  @@index([couponId, customerPhone])
}
