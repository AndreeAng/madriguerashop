# systemd unit para correr Nibble como servicio en un VPS.
# Copiar a /etc/systemd/system/nibble.service y activar con:
#   sudo systemctl enable --now nibble

[Unit]
Description=Nibble Next.js server
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/nibble/nibble
Environment=NODE_ENV=production
Environment=PORT=3000
EnvironmentFile=/var/www/nibble/nibble/.env
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=5

# Logs van a journal (ver con `journalctl -u nibble -f`)
StandardOutput=journal
StandardError=journal

# Hardening básico
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/www/uploads
ProtectHome=true

[Install]
WantedBy=multi-user.target
